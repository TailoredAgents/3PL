generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  OWNER
  SALES
  OPS
  ADMIN
}

enum ShipperStatus {
  LEAD
  ACTIVE
  INACTIVE
}

enum LeadStage {
  NEW
  CONTACTED
  QUALIFIED
  QUOTED
  WON
  LOST
}

enum LeadSource {
  AUDIT
  QUOTE_FORM
  REFERRAL
  MANUAL
  OUTBOUND
}

enum ActivityType {
  CALL
  EMAIL
  SMS
  NOTE
  AI_TOUCH
  MEETING
}

enum ActivityDirection {
  INBOUND
  OUTBOUND
  INTERNAL
}

enum AuditStatus {
  SUBMITTED
  PROCESSING
  COMPLETED
  FAILED
}

enum QuoteRequestStatus {
  NEW
  PRICING
  QUOTED
  ACCEPTED
  REJECTED
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

enum LoadStatus {
  TENDERED
  BOOKED
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  POD_RECEIVED
  INVOICED
  PAID
}

enum ComplianceStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

enum CarrierQuoteStatus {
  REQUESTED
  RECEIVED
  ACCEPTED
  REJECTED
}

enum ShipmentEventType {
  PICKUP_CONFIRMED
  LOCATION_UPDATE
  DELAY
  DELIVERED
  POD_UPLOADED
}

enum DocumentType {
  INVOICE
  POD
  RATE_CONFIRMATION
  AUDIT_UPLOAD
  OTHER
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIAL
  PAID
  OVERDUE
}

enum AiAgentStatus {
  STARTED
  COMPLETED
  FAILED
  NEEDS_HUMAN_APPROVAL
}

enum CustomerUpdateStatus {
  NOT_NEEDED
  NEEDED
  SENT
}

enum RateConfirmationStatus {
  NOT_STARTED
  DRAFTED
  SENT
  SIGNED
}

enum BrokerageCallDirection {
  INBOUND
  OUTBOUND
}

enum BrokerageCallStatus {
  RECEIVED
  IN_PROGRESS
  COMPLETED
  FAILED
}

enum CallRecordingStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  FAILED
  ABSENT
}

enum CallTranscriptStatus {
  NOT_REQUESTED
  PENDING
  COMPLETED
  FAILED
}

enum CallExtractionStatus {
  NOT_STARTED
  NEEDS_REVIEW
  APPROVED
  FAILED
}

enum RateBenchmarkSource {
  MANUAL
  INTERNAL_HISTORY
  DAT
  TRUCKSTOP
  CARRIER_QUOTE
  CUSTOMER_HISTORY
  OTHER
}

enum PricingRecommendationSource {
  MANUAL
  AI
  SYSTEM
}

enum CarrierSourcingSource {
  MANUAL
  INTERNAL_HISTORY
  DAT
  TRUCKSTOP
  CARRIER_NETWORK
  OTHER
}

enum CarrierSourcingStatus {
  NEW
  CONTACTED
  QUOTE_REQUESTED
  OFFER_RECEIVED
  REJECTED
  CONVERTED
}

enum IntegrationProvider {
  DAT
  TRUCKSTOP
  OTHER
}

enum IntegrationAction {
  RATE_LOOKUP
  CAPACITY_SEARCH
  LOAD_POST
  CARRIER_RESPONSE_SYNC
}

enum IntegrationStatus {
  SKIPPED
  SUCCESS
  FAILED
}

model User {
  id         String          @id @default(cuid())
  name       String
  email      String          @unique
  role       UserRole        @default(SALES)
  phone      String?
  leads      Lead[]          @relation("LeadOwner")
  activities Activity[]
  quotes     CustomerQuote[]
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
}

model Shipper {
  id            String         @id @default(cuid())
  companyName   String
  website       String?
  industry      String?
  status        ShipperStatus  @default(LEAD)
  source        LeadSource?
  notes         String?
  contacts      Contact[]
  leads         Lead[]
  activities    Activity[]
  audits        SavingsAudit[]
  quoteRequests QuoteRequest[]
  loads         Load[]
  documents     Document[]
  invoices      Invoice[]
  calls         BrokerageCall[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([companyName])
  @@index([status])
}

model Contact {
  id            String         @id @default(cuid())
  shipperId     String
  shipper       Shipper        @relation(fields: [shipperId], references: [id], onDelete: Cascade)
  firstName     String
  lastName      String?
  title         String?
  email         String?
  phone         String?
  isPrimary     Boolean        @default(false)
  leads         Lead[]
  activities    Activity[]
  audits        SavingsAudit[]
  quoteRequests QuoteRequest[]
  calls         BrokerageCall[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([email])
  @@index([shipperId])
}

model Lead {
  id                    String     @id @default(cuid())
  shipperId             String
  shipper               Shipper    @relation(fields: [shipperId], references: [id], onDelete: Cascade)
  contactId             String?
  contact               Contact?   @relation(fields: [contactId], references: [id], onDelete: SetNull)
  ownerUserId           String?
  owner                 User?      @relation("LeadOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  stage                 LeadStage  @default(NEW)
  source                LeadSource @default(MANUAL)
  priority              Int        @default(3)
  nextFollowUpAt        DateTime?
  estimatedMonthlySpend Decimal?   @db.Decimal(12, 2)
  notes                 String?
  activities            Activity[]
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  @@index([stage])
  @@index([source])
  @@index([nextFollowUpAt])
}

model Activity {
  id        String            @id @default(cuid())
  leadId    String?
  lead      Lead?             @relation(fields: [leadId], references: [id], onDelete: SetNull)
  shipperId String?
  shipper   Shipper?          @relation(fields: [shipperId], references: [id], onDelete: SetNull)
  contactId String?
  contact   Contact?          @relation(fields: [contactId], references: [id], onDelete: SetNull)
  userId    String?
  user      User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  type      ActivityType
  direction ActivityDirection @default(INTERNAL)
  subject   String?
  body      String?
  outcome   String?
  createdAt DateTime          @default(now())

  @@index([leadId])
  @@index([shipperId])
  @@index([createdAt])
}

model SavingsAudit {
  id                   String      @id @default(cuid())
  shipperId            String
  shipper              Shipper     @relation(fields: [shipperId], references: [id], onDelete: Cascade)
  contactId            String?
  contact              Contact?    @relation(fields: [contactId], references: [id], onDelete: SetNull)
  status               AuditStatus @default(SUBMITTED)
  extractedLanes       Json?
  estimatedSavingsLow  Decimal?    @db.Decimal(12, 2)
  estimatedSavingsHigh Decimal?    @db.Decimal(12, 2)
  reportSummary        String?
  reportUrl            String?
  grokConfidence       Decimal?    @db.Decimal(5, 2)
  documents            Document[]
  createdAt            DateTime    @default(now())
  completedAt          DateTime?

  @@index([status])
  @@index([createdAt])
}

model QuoteRequest {
  id                  String             @id @default(cuid())
  shipperId           String
  shipper             Shipper            @relation(fields: [shipperId], references: [id], onDelete: Cascade)
  contactId           String?
  contact             Contact?           @relation(fields: [contactId], references: [id], onDelete: SetNull)
  originCity          String
  originState         String
  originAddress       String?
  destinationCity     String
  destinationState    String
  destinationAddress  String?
  pickupDate          DateTime?
  pickupWindow        String?
  deliveryDate        DateTime?
  deliveryWindow      String?
  equipmentType       String
  commodity           String?
  weight              Int?
  palletCount         Int?
  pieceCount          Int?
  dimensions          String?
  hazmat              Boolean            @default(false)
  temperatureRequirement String?
  appointmentRequired Boolean            @default(false)
  accessorials        String?
  customerReference   String?
  urgency             String?
  intakeChannel       String             @default("PHONE")
  quotedByPhone       Boolean            @default(false)
  targetMarginPercent Decimal?           @db.Decimal(5, 2)
  pricingNotes        String?
  specialRequirements String?
  status              QuoteRequestStatus @default(NEW)
  customerQuotes      CustomerQuote[]
  rateBenchmarks      RateBenchmark[]
  pricingRecommendations PricingRecommendation[]
  loads               Load[]
  calls               BrokerageCall[]
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@index([status])
  @@index([pickupDate])
}

model CustomerQuote {
  id                   String       @id @default(cuid())
  quoteRequestId       String
  quoteRequest         QuoteRequest @relation(fields: [quoteRequestId], references: [id], onDelete: Cascade)
  quotedRate           Decimal      @db.Decimal(12, 2)
  targetCarrierCost    Decimal?     @db.Decimal(12, 2)
  projectedGrossProfit Decimal?     @db.Decimal(12, 2)
  marginPercent        Decimal?     @db.Decimal(5, 2)
  status               QuoteStatus  @default(DRAFT)
  validUntil           DateTime?
  createdByUserId      String?
  createdBy            User?        @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt            DateTime     @default(now())

  @@index([status])
}

model RateBenchmark {
  id             String              @id @default(cuid())
  quoteRequestId String
  quoteRequest   QuoteRequest        @relation(fields: [quoteRequestId], references: [id], onDelete: Cascade)
  source         RateBenchmarkSource @default(MANUAL)
  sourceLabel    String?
  lowRate        Decimal?            @db.Decimal(12, 2)
  highRate       Decimal?            @db.Decimal(12, 2)
  averageRate    Decimal             @db.Decimal(12, 2)
  confidence     Decimal?            @db.Decimal(5, 2)
  notes          String?
  createdAt      DateTime            @default(now())

  @@index([quoteRequestId])
  @@index([source])
  @@index([createdAt])
}

model PricingRecommendation {
  id                     String                      @id @default(cuid())
  quoteRequestId          String
  quoteRequest            QuoteRequest                @relation(fields: [quoteRequestId], references: [id], onDelete: Cascade)
  source                  PricingRecommendationSource @default(SYSTEM)
  recommendedCarrierCost  Decimal                     @db.Decimal(12, 2)
  recommendedCustomerRate Decimal                     @db.Decimal(12, 2)
  projectedGrossProfit    Decimal                     @db.Decimal(12, 2)
  marginPercent           Decimal                     @db.Decimal(5, 2)
  targetMarginPercent     Decimal?                    @db.Decimal(5, 2)
  riskLevel               String?
  validForHours           Int?
  summary                 String?
  notes                   String?
  createdAt               DateTime                    @default(now())

  @@index([quoteRequestId])
  @@index([source])
  @@index([createdAt])
}

model Load {
  id               String          @id @default(cuid())
  quoteRequestId   String?
  quoteRequest     QuoteRequest?   @relation(fields: [quoteRequestId], references: [id], onDelete: SetNull)
  shipperId        String
  shipper          Shipper         @relation(fields: [shipperId], references: [id], onDelete: Cascade)
  carrierId        String?
  carrier          Carrier?        @relation(fields: [carrierId], references: [id], onDelete: SetNull)
  status           LoadStatus      @default(TENDERED)
  originCity       String          @default("Unknown")
  originState      String          @default("NA")
  originAddress    String?
  destinationCity  String          @default("Unknown")
  destinationState String          @default("NA")
  destinationAddress String?
  equipmentType    String          @default("Dry van")
  commodity        String?
  weight           Int?
  palletCount      Int?
  pieceCount       Int?
  dimensions       String?
  hazmat           Boolean         @default(false)
  temperatureRequirement String?
  appointmentRequired Boolean      @default(false)
  accessorials     String?
  customerReference String?
  pickupWindow     String?
  deliveryWindow   String?
  customerRate     Decimal         @db.Decimal(12, 2)
  carrierRate      Decimal?        @db.Decimal(12, 2)
  grossProfit      Decimal?        @db.Decimal(12, 2)
  pickupDate       DateTime?
  deliveryDate     DateTime?
  customerUpdateStatus CustomerUpdateStatus @default(NOT_NEEDED)
  lastCustomerUpdateAt DateTime?
  rateConfirmationStatus RateConfirmationStatus @default(NOT_STARTED)
  rateConfirmationSentAt DateTime?
  rateConfirmationSignedAt DateTime?
  sourcingCandidates CarrierSourcingCandidate[]
  integrationLogs   IntegrationLog[]
  carrierQuotes    CarrierQuote[]
  events           ShipmentEvent[]
  documents        Document[]
  invoice          Invoice?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([status])
  @@index([pickupDate])
}

model Carrier {
  id               String           @id @default(cuid())
  companyName      String
  mcNumber         String?
  dotNumber        String?
  contactName      String?
  phone            String?
  email            String?
  complianceStatus ComplianceStatus @default(PENDING)
  authorityStatus  String?
  insuranceStatus  String?
  safetyRating     String?
  fraudRiskLevel   String?
  lastVettedAt     DateTime?
  approvedBy       String?
  complianceNotes  String?
  preferredLanes   Json?
  notes            String?
  loads            Load[]
  carrierQuotes    CarrierQuote[]
  sourcingCandidates CarrierSourcingCandidate[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([companyName])
  @@index([mcNumber])
  @@index([dotNumber])
  @@index([complianceStatus])
}

model CarrierQuote {
  id         String             @id @default(cuid())
  loadId     String
  load       Load               @relation(fields: [loadId], references: [id], onDelete: Cascade)
  carrierId  String
  carrier    Carrier            @relation(fields: [carrierId], references: [id], onDelete: Cascade)
  quotedRate Decimal            @db.Decimal(12, 2)
  status     CarrierQuoteStatus @default(REQUESTED)
  notes      String?
  createdAt  DateTime           @default(now())

  @@index([loadId])
  @@index([carrierId])
  @@index([status])
}

model CarrierSourcingCandidate {
  id                  String                @id @default(cuid())
  loadId              String
  load                Load                  @relation(fields: [loadId], references: [id], onDelete: Cascade)
  carrierId           String?
  carrier             Carrier?              @relation(fields: [carrierId], references: [id], onDelete: SetNull)
  source              CarrierSourcingSource @default(MANUAL)
  status              CarrierSourcingStatus @default(NEW)
  companyName         String
  contactName         String?
  phone               String?
  email               String?
  mcNumber            String?
  dotNumber           String?
  suggestedRate       Decimal?              @db.Decimal(12, 2)
  matchScore          Decimal?              @db.Decimal(5, 2)
  complianceSnapshot  String?
  notes               String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  @@index([loadId])
  @@index([carrierId])
  @@index([source])
  @@index([status])
}

model IntegrationLog {
  id             String              @id @default(cuid())
  provider       IntegrationProvider
  action         IntegrationAction
  status         IntegrationStatus
  loadId         String?
  load           Load?               @relation(fields: [loadId], references: [id], onDelete: SetNull)
  quoteRequestId String?
  requestJson    Json?
  responseJson   Json?
  externalId     String?
  message        String?
  error          String?
  createdAt      DateTime            @default(now())

  @@index([provider])
  @@index([action])
  @@index([status])
  @@index([loadId])
  @@index([quoteRequestId])
  @@index([createdAt])
}

model ShipmentEvent {
  id         String            @id @default(cuid())
  loadId     String
  load       Load              @relation(fields: [loadId], references: [id], onDelete: Cascade)
  type       ShipmentEventType
  message    String
  location   String?
  occurredAt DateTime
  createdAt  DateTime          @default(now())

  @@index([loadId])
  @@index([occurredAt])
}

model Document {
  id             String        @id @default(cuid())
  shipperId      String?
  shipper        Shipper?      @relation(fields: [shipperId], references: [id], onDelete: SetNull)
  loadId         String?
  load           Load?         @relation(fields: [loadId], references: [id], onDelete: SetNull)
  savingsAuditId String?
  savingsAudit   SavingsAudit? @relation(fields: [savingsAuditId], references: [id], onDelete: SetNull)
  type           DocumentType
  fileName       String
  fileUrl        String
  extractedText  String?
  createdAt      DateTime      @default(now())

  @@index([shipperId])
  @@index([loadId])
  @@index([savingsAuditId])
}

model Invoice {
  id        String        @id @default(cuid())
  loadId    String        @unique
  load      Load          @relation(fields: [loadId], references: [id], onDelete: Cascade)
  shipperId String
  shipper   Shipper       @relation(fields: [shipperId], references: [id], onDelete: Cascade)
  amount    Decimal       @db.Decimal(12, 2)
  status    InvoiceStatus @default(DRAFT)
  dueDate   DateTime?
  paidAt    DateTime?
  createdAt DateTime      @default(now())

  @@index([status])
  @@index([dueDate])
}

model AiAgentRun {
  id                String        @id @default(cuid())
  agentName         String
  relatedEntityType String?
  relatedEntityId   String?
  status            AiAgentStatus @default(STARTED)
  prompt            String?
  inputJson         Json?
  outputJson        Json?
  confidence        Decimal?      @db.Decimal(5, 2)
  errorMessage      String?
  createdAt         DateTime      @default(now())

  @@index([agentName])
  @@index([relatedEntityType, relatedEntityId])
  @@index([createdAt])
}

model BrokerageCall {
  id                String               @id @default(cuid())
  direction         BrokerageCallDirection @default(INBOUND)
  status            BrokerageCallStatus  @default(RECEIVED)
  twilioCallSid     String?              @unique
  fromPhone         String?
  toPhone           String?
  callerName        String?
  shipperId         String?
  shipper           Shipper?             @relation(fields: [shipperId], references: [id], onDelete: SetNull)
  contactId         String?
  contact           Contact?             @relation(fields: [contactId], references: [id], onDelete: SetNull)
  quoteRequestId    String?
  quoteRequest      QuoteRequest?        @relation(fields: [quoteRequestId], references: [id], onDelete: SetNull)
  recordingSid      String?
  recordingUrl      String?
  recordingDuration Int?
  recordingStatus   CallRecordingStatus  @default(NOT_STARTED)
  transcriptText    String?
  transcriptStatus  CallTranscriptStatus @default(NOT_REQUESTED)
  aiSummary         String?
  aiExtractedJson   Json?
  missingQuestions  Json?
  extractionStatus  CallExtractionStatus @default(NOT_STARTED)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@index([twilioCallSid])
  @@index([fromPhone])
  @@index([shipperId])
  @@index([contactId])
  @@index([quoteRequestId])
  @@index([createdAt])
}

model AppSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
}
